{
  "formatVersion": 3,
  "id": "${p_id}",
  "version": "${p_version}",
  "display_name": "${p_name}",
  "name": "${p_name}",
  "description": "${p_desc}",
  "authors": [
    "DarkMattrMaestro"
  ],
  "meta": {
    "icon": "${p_id}:icons/icon.png"
  },
  "entrypoints": {
    "client-init": [
      "com.darkmattrmaestro.imgui_example.ClientInitializer"
    ]
  },
  "depends": {
    "cosmic-reach": ">=${cosmic_reach_version}",
    "puzzle-loader-cosmic": ">=${puzzle_loader_cosmic_version}",
    "puzzle-loader-core": ">=${puzzle_loader_core_version}"
  },
  "allowedSides": {
    "client": true,
    "server": false
  },
  "mixins": [
    {
      "config": "imgui_example.mixins.json",
      "environment": "client"
    }
  ]
}